{
  "name": "@peaske7/readit",
  "version": "0.1.4",
  "description": "A CLI tool to review Markdown documents with inline comments",
  "author": "Jay Shimada <peaske@pm.me>",
  "license": "MIT",
  "keywords": [
    "markdown",
    "review",
    "cli",
    "comments",
    "documentation"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "NODE_ENV=development bun --watch src/cli/index.ts -- test.md & bunx vite",
    "build": "bunx vite build && bun run build:cli",
    "build:cli": "bun build src/cli/index.ts --outdir dist --target bun --format esm --packages external",
    "start": "bun run build && bun dist/index.js",
    "test": "vitest run",
    "bench": "vitest bench",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "prepack": "bun run build",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "dompurify": "^3.3.3",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "open": "^11.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-parse": "^9.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-react": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.10",
    "@types/dompurify": "^3.2.0",
    "@types/jsdom": "^28.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^28.1.0",
    "lefthook": "^2.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
